</head>
<body>
  <header class="site-header">
    <a class="site-brand" href="index.html" aria-label="StockSensei home">
      <span class="site-brand-mark" aria-hidden="true">
      <svg class="stocksensei-logo-svg" viewBox="0 0 64 64" role="img">
        <g class="logo-candles">
          <path d="M9 19v28" />
          <rect x="6" y="25" width="7" height="15" rx="1.5" />
          <path d="M19 11v36" />
          <rect x="16" y="18" width="7" height="22" rx="1.5" />
          <path d="M55 17v30" />
          <rect x="51.5" y="22" width="7" height="19" rx="1.5" />
        </g>
        <path class="logo-swoosh" d="M10 49c10 7 33 7 44 0" />
        <g class="logo-sensei">
          <path class="logo-robe" d="M15 49c4-15 10-24 17-27 8 3 14 12 17 27-9 7-25 7-34 0Z" />
          <path class="logo-robe-accent" d="M19 49c4-10 8-17 13-20 5 3 10 10 14 20-8 4-19 4-27 0Z" />
          <path class="logo-face" d="M20 31c4-8 8-12 12-12s9 4 13 12c-6 6-19 6-25 0Z" />
          <path class="logo-beard" d="M22 33c5 5 15 5 20 0-1 7-5 13-10 13s-9-6-10-13Z" />
          <path class="logo-hair" d="M19 29c6-4 20-4 26 0-2-9-7-15-13-15s-11 6-13 15Z" />
          <path class="logo-bun" d="M23 14c3-8 15-8 18 0-4 5-14 5-18 0Z" />
          <path class="logo-features" d="M23 31c6 3 12 3 18 0M25 36c5 3 9 3 14 0" />
        </g>
        <path class="logo-sparkline" d="M7 45 L17 45 L24 35 L31 39 L39 25 L47 30 L57 16" />
      </svg>
    </span>
      <span class="site-brand-text"><span>STOCK</span><span class="sensei">SENSEI</span></span>
    </a>
    <nav class="site-nav" aria-label="Main navigation">
      <a href="index.html">Home</a>
      <a href="Predict.html">Predict</a>
      <a href="learn.html">Learn</a>
      <a href="watchlist.html">Watchlist</a>
      <a href="explore.html">Explore</a>
      <a href="About.html">About Us</a>
      <div id="userArea"></div>
    </nav>
  </header>

  <main class="login-container">
    <section class="login-card profile-card">
      <div class="logo-circle" id="avatar">SS</div>
      <h1>Your Profile</h1>
      <p id="email">Loading...</p>
      <div id="message" class="message" role="status" aria-live="polite"></div>

      <div class="input-group">
        <label for="username">Username</label>
        <div class="input-box"><input id="username" placeholder="username"></div>
      </div>

      <div class="input-group">
        <label for="displayName">Display Name</label>
        <div class="input-box"><input id="displayName" placeholder="Display name"></div>
      </div>

      <button class="primary-btn" onclick="saveProfile()" type="button">Save Profile</button>

      <div class="input-group profile-section">
        <label for="newPassword">New Password</label>
        <div class="input-box"><input id="newPassword" type="password" placeholder="New password"></div>
      </div>

      <button class="secondary-btn" onclick="changePassword()" type="button">Change Password</button>

      <p class="guest">Watchlist stocks: <strong id="watchCount">0</strong></p>
    </section>
  </main>

  <footer class="site-footer">
    <div class="site-footer-inner">
      <div>
        <strong>Education Only Disclaimer</strong>
        <p>StockSensei is an educational stock analysis tool. Forecasts, model outputs, charts, and market data shown here are not financial advice.</p>
      </div>
      <div class="site-footer-copy">© 2026 StockSensei. All rights reserved.</div>
    </div>
  </footer>

  <script src="supabase.js"></script>
  <script src="session.js"></script>
  <script src="profile.js"></script>
</body>
</html>
